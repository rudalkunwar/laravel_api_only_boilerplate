{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "rudalkunwar/laravel_api_only_boilerplate",
    "type": "project",
    "description": "Enterprise-grade, strictly-typed Laravel API-only boilerplate with DDD, repositories, full auth, and complete test coverage.",
    "keywords": [
        "laravel",
        "api",
        "boilerplate",
        "ddd",
        "sanctum",
        "enterprise"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.4.0",
        "laravel/framework": "^13.5",
        "laravel/octane": "^2.0",
        "laravel/sanctum": "^4.0",
        "spatie/laravel-permission": "^8.0"
    },
    "require-dev": {
        "driftingly/rector-laravel": "^2.0",
        "fakerphp/faker": "^1.24",
        "larastan/larastan": "^3.0",
        "laravel/boost": "^2.0",
        "laravel/pail": "^1.0",
        "laravel/pint": "^1.29",
        "laravel/tinker": "^3.0",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^4.7",
        "pestphp/pest-plugin-laravel": "^4.1",
        "rector/rector": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan boost:update --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "lint": "pint",
        "refactor": "rector",
        "analyse": "phpstan analyse --memory-limit=512M",
        "test:lint": "pint --test",
        "test:refactor": "rector --dry-run",
        "test:types": "phpstan analyse --memory-limit=512M",
        "test:unit": "pest --colors=always",
        "test:coverage": "XDEBUG_MODE=coverage pest --colors=always --coverage --min=90",
        "test": [
            "@test:lint",
            "@test:refactor",
            "@test:types",
            "@test:unit"
        ],
        "ci": [
            "@test:lint",
            "@test:refactor",
            "@test:types",
            "@test:coverage"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
